{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "nixpacksPlan": {
      "phases": {
        "setup": {
          "nixPkgs": ["nodejs_20", "npm-9_x", "openssl"]
        },
        "install": {
          "cmds": ["npm install --legacy-peer-deps"]
        }
      }
    }
  },
  "deploy": {
    "startCommand": "node dist/worker.js",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
